# Web3Forms API Key — get yours for free at https://web3forms.com
# This key is used to forward contact form & newsletter submissions to your email.
# Set the destination email address on your Web3Forms dashboard.
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_key_here

# Server-side Web3Forms key (kept private, never exposed to client)
# Copy the same key — this is consumed by the API route, not the browser
WEB3FORMS_KEY=your_web3forms_key_here
